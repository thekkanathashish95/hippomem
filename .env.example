# hippomem environment variables
# Copy to .env and fill in your values: cp .env.example .env

# ── Required ───────────────────────────────────────────────────────────────────

# Your OpenAI-compatible API key
LLM_API_KEY=sk-...

# ── Optional — defaults shown ──────────────────────────────────────────────────

# Base URL for your LLM provider (OpenAI-compatible)
# Alternatives: https://api.openai.com/v1
LLM_BASE_URL=https://openrouter.ai/api/v1

# Model hippomem uses for its internal memory operations (extraction, synthesis, etc.)
LLM_MODEL=google/gemini-3.1-flash-lite-preview

# Model used for the /chat endpoint in daemon mode (defaults to LLM_MODEL if unset)
# CHAT_MODEL=gpt-4o

# Base system prompt injected before memory context in daemon mode
# SYSTEM_PROMPT=You are a helpful assistant with access to long-term memory about the user.

# SQLite database path (relative to working directory)
# DB_URL=sqlite:///hippomem.db

# Directory for FAISS vector index files
# VECTOR_DIR=./hippomem_vectors
